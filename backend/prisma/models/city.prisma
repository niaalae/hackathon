model Region {
  id       String @id @default(uuid())
  name_key String @unique
  cities   City[]
  translations RegionTranslation[]
}

model City {
  id       String   @id @default(uuid())
  name_key String   @unique
  coords   Json
  images   String[]
  regionId String
  region   Region   @relation(fields: [regionId], references: [id])
  trips    Trip[]
  places   Place[]
  translations CityTranslation[]
}

model Language {
  id       String @id @default(uuid())
  language String @unique

  regionTranslations   RegionTranslation[]
  cityTranslations     CityTranslation[]
  categoryTranslations CategoryTranslation[]
  placeTranslations    PlaceTranslation[]
}

model RegionTranslation {
  id         String @id @default(uuid())
  regionId   String
  languageId String
  name       String

  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([regionId, languageId])
}

model CityTranslation {
  id         String @id @default(uuid())
  cityId     String
  languageId String
  name       String

  city     City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([cityId, languageId])
}
