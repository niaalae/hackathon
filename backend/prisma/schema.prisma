generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TRAVELER
  GUIDE
  ADMIN
}

enum TripStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELED
}

enum CollaboratorRole {
  OWNER
  EDITOR
  VIEWER
}

enum BookingType {
  FLIGHT
  STAY
  EXPERIENCE
  RENTAL
  GUIDE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum SwipeDirection {
  LIKE
  PASS
}

enum MatchStatus {
  ACTIVE
  BLOCKED
}

enum InfoScope {
  REGION
  CITY
  ATTRACTION
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(TRAVELER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  preferences  Json?

  guideProfile Guide?
  tripsOwned   Trip[]   @relation("TripOwner")
  collabs      TripCollaborator[]
  bookings     Booking[]
  ratingsGiven Rating[]  @relation("RatingFromUser")
  messagesSent Message[] @relation("MessageFromUser")
  swipes       Swipe[]   @relation("SwipeFromUser")
  matches      Match[]   @relation("MatchUser")

  @@map("users")
}

model Guide {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  headline       String?
  bio            String?
  rateHourly     Decimal? @map("rate_hourly") @db.Decimal(10, 2)
  rateDaily      Decimal? @map("rate_daily") @db.Decimal(10, 2)
  locationCityId String?  @map("location_city_id")
  contactEmail   String?  @map("contact_email")
  contactPhone   String?  @map("contact_phone")
  verified       Boolean  @default(false)
  ratingAvg      Decimal? @map("rating_avg") @db.Decimal(3, 2)
  ratingCount    Int      @default(0) @map("rating_count")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationCity City?     @relation("CityGuides", fields: [locationCityId], references: [id])
  media        GuideMedia[]
  pastTrips    GuidePastTrip[]
  ratings      Rating[]
  messages     Message[] @relation("MessageToGuide")
  swipesTarget Swipe[]   @relation("SwipeToGuide")
  matches      Match[]   @relation("MatchGuide")

  @@map("guides")
}

model GuideMedia {
  id       String   @id @default(uuid())
  guideId  String   @map("guide_id")
  type     MediaType
  url      String
  caption  String?
  position Int      @default(0)

  guide    Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@map("guide_media")
}

model GuidePastTrip {
  id        String    @id @default(uuid())
  guideId   String    @map("guide_id")
  title     String
  location  String
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  summary   String?
  mediaUrl  String?   @map("media_url")

  guide     Guide     @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@map("guide_past_trips")
}

model Trip {
  id          String     @id @default(uuid())
  ownerUserId String     @map("owner_user_id")
  title       String
  status      TripStatus @default(DRAFT)
  startDate   DateTime?  @map("start_date")
  endDate     DateTime?  @map("end_date")
  budgetTotal Decimal?   @map("budget_total") @db.Decimal(12, 2)
  currency    String?    @default("USD")

  owner         User                 @relation("TripOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  collaborators TripCollaborator[]
  items         TripItem[]
  bookings      Booking[]
  ratings       Rating[]
  messages      Message[]

  @@index([ownerUserId])
  @@map("trips")
}

model TripCollaborator {
  tripId   String           @map("trip_id")
  userId   String           @map("user_id")
  role     CollaboratorRole @default(VIEWER)
  joinedAt DateTime         @default(now()) @map("joined_at")

  trip     Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tripId, userId])
  @@map("trip_collaborators")
}

model TripItem {
  id       String   @id @default(uuid())
  tripId   String   @map("trip_id")
  day      Int?
  title    String
  location String?
  time     DateTime?
  notes    String?
  type     String?

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_items")
}

model Booking {
  id          String        @id @default(uuid())
  tripId      String        @map("trip_id")
  userId      String        @map("user_id")
  type        BookingType
  provider    String?
  externalRef String?       @map("external_ref")
  price       Decimal?      @db.Decimal(12, 2)
  currency    String?       @default("USD")
  status      BookingStatus @default(PENDING)
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")

  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
  @@map("bookings")
}

model Rating {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  guideId    String   @map("guide_id")
  tripId     String?  @map("trip_id")
  score      Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User  @relation("RatingFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  guide    Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  trip     Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([guideId])
  @@index([fromUserId])
  @@map("ratings")
}

model Message {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toGuideId  String   @map("to_guide_id")
  tripId     String?  @map("trip_id")
  message    String
  status     String?
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User  @relation("MessageFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toGuide  Guide @relation("MessageToGuide", fields: [toGuideId], references: [id], onDelete: Cascade)
  trip     Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([toGuideId])
  @@map("messages")
}

model Swipe {
  id            String         @id @default(uuid())
  fromUserId    String         @map("from_user_id")
  targetUserId  String?        @map("target_user_id")
  targetGuideId String?        @map("target_guide_id")
  direction     SwipeDirection
  createdAt     DateTime       @default(now()) @map("created_at")

  fromUser    User   @relation("SwipeFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  targetGuide Guide? @relation("SwipeToGuide", fields: [targetGuideId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@map("swipes")
}

model Match {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  targetUserId String?     @map("target_user_id")
  guideId      String?     @map("guide_id")
  status       MatchStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")

  user  User   @relation("MatchUser", fields: [userId], references: [id], onDelete: Cascade)
  guide Guide? @relation("MatchGuide", fields: [guideId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("matches")
}

model Region {
  id          String   @id @default(uuid())
  name        String
  country     String
  slug        String   @unique
  description String?
  coverImage  String?  @map("cover_image")

  cities     City[]
  infoBlocks InfoBlock[] @relation("RegionInfo")

  @@map("regions")
}

model City {
  id          String   @id @default(uuid())
  regionId    String   @map("region_id")
  name        String
  slug        String   @unique
  lat         Decimal? @db.Decimal(9, 6)
  lng         Decimal? @db.Decimal(9, 6)
  timezone    String?
  description String?
  coverImage  String?  @map("cover_image")

  region      Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  attractions Attraction[]
  guides      Guide[]  @relation("CityGuides")
  infoBlocks  InfoBlock[] @relation("CityInfo")

  @@index([regionId])
  @@map("cities")
}

model Attraction {
  id              String   @id @default(uuid())
  cityId          String   @map("city_id")
  name            String
  slug            String   @unique
  type            String?
  lat             Decimal? @db.Decimal(9, 6)
  lng             Decimal? @db.Decimal(9, 6)
  description     String?
  avgPrice        Decimal? @map("avg_price") @db.Decimal(10, 2)
  durationMinutes Int?     @map("duration_minutes")
  coverImage      String?  @map("cover_image")

  city       City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  media      AttractionMedia[]
  tags       AttractionTagMap[]
  infoBlocks InfoBlock[] @relation("AttractionInfo")

  @@index([cityId])
  @@map("attractions")
}

model AttractionMedia {
  id           String   @id @default(uuid())
  attractionId String   @map("attraction_id")
  type         MediaType
  url          String
  caption      String?
  position     Int      @default(0)

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@index([attractionId])
  @@map("attraction_media")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique

  attractions AttractionTagMap[]

  @@map("tags")
}

model AttractionTagMap {
  attractionId String @map("attraction_id")
  tagId        String @map("tag_id")

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([attractionId, tagId])
  @@map("attraction_tag_map")
}

model InfoBlock {
  id           String    @id @default(uuid())
  scope        InfoScope
  regionId     String?   @map("region_id")
  cityId       String?   @map("city_id")
  attractionId String?   @map("attraction_id")
  title        String
  content      String
  category     String?
  language     String?   @default("en")

  region     Region?     @relation("RegionInfo", fields: [regionId], references: [id], onDelete: Cascade)
  city       City?       @relation("CityInfo", fields: [cityId], references: [id], onDelete: Cascade)
  attraction Attraction? @relation("AttractionInfo", fields: [attractionId], references: [id], onDelete: Cascade)

  @@index([regionId])
  @@index([cityId])
  @@index([attractionId])
  @@map("info_blocks")
}

model Translation {
  id         String @id @default(uuid())
  entityType String @map("entity_type")
  entityId   String @map("entity_id")
  language   String
  field      String
  value      String

  @@index([entityType, entityId])
  @@map("translations")
}
